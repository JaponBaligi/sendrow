# Set the same variables on your host (e.g. Railway).
# API server (see server/index.js)
AIRTABLE_PAT=
AIRTABLE_BASE_ID=

# Auth for GET /api/copy (at least one):
# Option A — Airtable button (same token in URL formula + here)
COPY_STATIC_TOKEN=

# Option B — signed links from npm run generate-copy-link
COPY_LINK_SECRET=

# Tables: prefer IDs from the Airtable URL (…/tblXXXX/…) — avoids name typos
# SOURCE_TABLE_ID=tblxxxxxxxxxxxxxx
# TARGET_TABLE_ID=tblxxxxxxxxxxxxxx
SOURCE_TABLE_NAME=News
TARGET_TABLE_NAME=Create
# COPY_FIELD_MAP=Title:Name,Content:Text,Title:Caption,Category:Category

PORT=3000

# npm run generate-copy-link (full URL)
PUBLIC_BASE_URL=
